# /etc/default/hermitstash-sync-update — environment overrides for the
# hermitstash-sync-update systemd service. Uncomment and edit lines below
# to change updater behaviour; blank / missing values fall back to the
# defaults documented in update.sh.
#
# Installed to /etc/default/hermitstash-sync-update by deploy/install.sh.

# Set to "off" to pause auto-updates without disabling the timer entirely.
# UPDATE_CHANNEL=stable

# Pin to a specific version (otherwise: latest release matching current major).
# VERSION=0.4.7

# Extend the post-restart health window if your host is slow to come online.
# HEALTH_TIMEOUT=60

# Use a fork or private mirror.
# GITHUB_REPO=dotCooCoo/hermitstash-sync
